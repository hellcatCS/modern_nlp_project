# ========== Чтобы НЕ ходить в OpenAI API для чата ==========
# Обязательно строка ниже (true / 1 / yes). Имя именно USE_VLLM_LLM (две L подряд).
USE_VLLM_LLM=true
# Опционально: OPENAI_API_KEY оставьте пустым или закомментируйте
OPENAI_API_KEY=

VLLM_BASE_URL=http://127.0.0.1:8000/v1
VLLM_MODEL_PATH=/home/aesemikin/models/Qwen3-30B-A3B
# Должно совпадать с --served-model-name. Сервер vLLM для tools: --enable-auto-tool-choice --tool-call-parser hermes (или qwen3_xml для Qwen3-Coder) — см. README
VLLM_MODEL=Qwen3-30B-A3B
VLLM_API_KEY=EMPTY

# ========== Режим с OpenAI (если USE_VLLM_LLM=false) ==========
# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=text-embedding-3-small

# При `docker compose --profile app run app` у app network_mode:host — БД/Qdrant на localhost
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/restaurant_bot
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION_PREFIX=restaurant_knowledge
RAG_TOP_K=7
RAG_MIN_SCORE=0.05

# Наблюдаемость (по умолчанию включено; docker compose up поднимает ES/Kibana/Prometheus/Grafana)
OBSERVABILITY_ENABLED=true
ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_URL=http://127.0.0.1:9200
ELASTICSEARCH_INDEX_PREFIX=restaurant-bot-logs
PROMETHEUS_METRICS_ENABLED=true

# Telegram userbot (tg_manager)
TG_API_ID=
TG_API_HASH=
